---
import content from '../data/content.json';

const { header, site } = content;
---

<header class="header">
  <div class="container header__inner">
    <a href="/" class="header__logo" aria-label={site.logo.alt}>
      <img
        src={site.logo.image}
        alt={site.logo.alt}
        class="header__logo-img"
        width="64"
        height="64"
      />
    </a>

    <nav class="header__nav" aria-label="Navegación principal">
      <a href="/" class="header__nav-link">Inicio</a>
      <a href="/catalogo" class="header__nav-link">Catálogo</a>
    </nav>

    <a href={header.cta.href} class="btn-primary header__cta">
      {header.cta.text}
    </a>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(13, 10, 8, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(200, 148, 58, 0.15);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }

  .header__logo {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .header__logo-img {
    width: 60px;
    height: 60px;
    object-fit: contain;
    border-radius: 50%;
  }

  .header__logo-text {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--color-white);
    letter-spacing: 0.02em;
  }

  .header__nav {
    display: flex;
    gap: 28px;
    align-items: center;
  }

  .header__nav-link {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }

  .header__nav-link:hover {
    color: var(--color-gold);
  }

  .header__cta {
    font-size: 0.88rem;
    padding: 10px 24px;
  }

  @media (max-width: 600px) {
    .header__nav {
      gap: 18px;
    }

    .header__nav-link {
      font-size: 0.82rem;
    }

    .header__cta {
      display: none;
    }
  }

  @media (max-width: 380px) {
    .header__nav {
      display: none;
    }
  }
</style>
