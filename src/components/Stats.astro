---
import content from '../data/content.json';

const { stats } = content;
---

<section class="stats">
  <div class="container stats__inner">
    <h2 class="stats__headline">
      <span class="stats__headline-white">{stats.headline}</span>
      {' '}{stats.headlineEnd}
    </h2>

    <div class="stats__grid">
      {stats.items.map((item) => (
        <div class="stat-item">
          <div class={`stat-item__value ${item.isIcon ? 'stat-item__value--icon' : 'stat-item__value--gradient'}`}>
            {item.isIcon
              ? <img src={item.iconImage} alt={item.label} class="stat-item__map-icon" />
              : item.value
            }
          </div>
          <p class="stat-item__label">{item.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats {
    position: relative;
    padding: 90px 0;
    overflow: hidden;
  }

  .stats__inner {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .stats__headline {
    font-size: clamp(1.5rem, 3.5vw, 2.2rem);
    font-weight: 700;
    color: var(--color-gold);
    margin-bottom: 60px;
    line-height: 1.3;
  }

  .stats__headline-white {
    color: var(--color-white);
  }

  .stats__grid {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: 0;
    flex-wrap: wrap;
  }

  .stat-item {
    flex: 1;
    min-width: 180px;
    padding: 20px 32px;
    border-right: 1px solid rgba(200, 148, 58, 0.2);
  }

  .stat-item:last-child {
    border-right: none;
  }

  .stat-item__value {
    font-size: clamp(3.2rem, 8vw, 5.2rem);
    font-weight: 900;
    line-height: 1;
    margin-bottom: 12px;
  }

  .stat-item__value--gradient {
    background: linear-gradient(135deg, #f5d06a 0%, #c8943a 40%, #f0b429 70%, #a06820 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 2px 8px rgba(200, 148, 58, 0.4));
  }

  .stat-item__value--icon {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .stat-item__map-icon {
    width: clamp(60px, 10vw, 90px);
    height: auto;
  }

  .stat-item__label {
    font-size: 1.20rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.4;
    max-width: 140px;
    margin: 0 auto;
  }

  @media (max-width: 600px) {
    .stats__grid {
      flex-direction: column;
      align-items: center;
      gap: 32px;
    }

    .stat-item {
      border-right: none;
      border-bottom: 1px solid rgba(200, 148, 58, 0.2);
      padding-bottom: 32px;
    }

    .stat-item:last-child {
      border-bottom: none;
    }
  }
</style>
